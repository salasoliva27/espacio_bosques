# ── espacio-bosques environment configuration ───
#
# Keys marked [DOTFILES] are loaded automatically from salasoliva27/dotfiles/.env
# into every Codespace. Do NOT duplicate their values here.
# Keys marked [PROJECT] are specific to this project — set them here.
#

# ── MODE ─────────────────────────────────────────
SIMULATION_MODE=true                              # [PROJECT]

# ── ANTHROPIC ────────────────────────────────────
# ANTHROPIC_API_KEY                               # [DOTFILES] — auto-loaded from dotfiles
ANTHROPIC_MODEL=claude-sonnet-4-20250514          # [PROJECT]
ANTHROPIC_MAX_TOKENS=4096                         # [PROJECT]

# ── SUPABASE ─────────────────────────────────────
# SUPABASE_URL                                    # [DOTFILES] — auto-loaded from dotfiles
# SUPABASE_SERVICE_ROLE_KEY                       # [DOTFILES] — auto-loaded from dotfiles
# SUPABASE_ANON_KEY uses same value as service role in dev (shared Supabase instance)
SUPABASE_ANON_KEY=${SUPABASE_SERVICE_ROLE_KEY}    # [DOTFILES] — derived from dotfiles

# ── BITSO ────────────────────────────────────────
# BITSO_API_KEY                                   # [DOTFILES] — auto-loaded from dotfiles
# BITSO_API_SECRET                                # [DOTFILES] — auto-loaded from dotfiles
BITSO_SANDBOX_URL=https://api-dev.bitso.com/v3   # [PROJECT] — static URL
BITSO_PROD_URL=https://api.bitso.com/v3          # [PROJECT] — static URL

# ── BLOCKCHAIN ───────────────────────────────────
RPC_URL=http://127.0.0.1:8545                    # [PROJECT] — local Hardhat
BACKEND_WALLET_PRIVATE_KEY=                       # [PROJECT] — generated per deployment
BACKEND_WALLET_ADDRESS=                           # [PROJECT] — generated per deployment
CONTRACT_ADDRESS=                                 # [PROJECT] — set after deploy

# ── GOOGLE AUTH ──────────────────────────────────
# GOOGLE_CLIENT_ID                                # [DOTFILES] — auto-loaded from dotfiles
# GOOGLE_CLIENT_SECRET                            # [DOTFILES] — auto-loaded from dotfiles

# ── BACKEND ──────────────────────────────────────
NODE_ENV=development                              # [PROJECT]
PORT=3001                                         # [PROJECT]
CORS_ORIGIN=http://localhost:5173                 # [PROJECT]
JWT_SECRET=change-in-production                   # [PROJECT] — rotate for prod
JWT_EXPIRES_IN=7d                                 # [PROJECT]

# ── LEGACY (Prisma / PostgreSQL) ──────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.supabase.co:5432/postgres?schema=public  # [PROJECT]

# ── FRONTEND (Vite) ──────────────────────────────
VITE_SUPABASE_URL=https://rycybujjedtofghigyxm.supabase.co  # [PROJECT] — public, safe in frontend
VITE_SUPABASE_ANON_KEY=                           # [PROJECT] — set from Supabase dashboard
VITE_SIMULATION_MODE=true                         # [PROJECT]
VITE_CONTRACT_ADDRESS=                            # [PROJECT]
VITE_RPC_URL=http://127.0.0.1:8545               # [PROJECT]
VITE_API_URL=http://localhost:3001                # [PROJECT]

# ── MONITORING ───────────────────────────────────
TELEMETRY_RETENTION_DAYS=90                       # [PROJECT]
REPORT_GENERATION_INTERVAL_HOURS=24               # [PROJECT]

# ── RATE LIMITING ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000                       # [PROJECT]
RATE_LIMIT_MAX_REQUESTS=100                       # [PROJECT]

# ── Spline 3D scenes ────────────────────────────
VITE_SPLINE_HERO=https://prod.spline.design/kUJZ1MiBGg7E7wzh/scene.splinecode   # [PROJECT]
VITE_SPLINE_ACCENT=https://prod.spline.design/fJ2ptJKzT-sDkpfO/scene.splinecode # [PROJECT]
