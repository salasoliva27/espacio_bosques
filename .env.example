# ── MODE ─────────────────────────────────────────
SIMULATION_MODE=true

# ── ANTHROPIC ────────────────────────────────────
ANTHROPIC_API_KEY=your_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# ── SUPABASE ─────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# ── BITSO ────────────────────────────────────────
BITSO_API_KEY=your_key
BITSO_API_SECRET=your_secret
BITSO_SANDBOX_URL=https://api-dev.bitso.com/v3
BITSO_PROD_URL=https://api.bitso.com/v3

# ── BLOCKCHAIN ───────────────────────────────────
RPC_URL=http://127.0.0.1:8545
BACKEND_WALLET_PRIVATE_KEY=
BACKEND_WALLET_ADDRESS=
CONTRACT_ADDRESS=

# ── GOOGLE AUTH ──────────────────────────────────
GOOGLE_CLIENT_ID=your_id
GOOGLE_CLIENT_SECRET=your_secret

# ── BACKEND ──────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── LEGACY (Prisma / PostgreSQL) ──────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST.supabase.co:5432/postgres?schema=public

# ── FRONTEND (Vite) ──────────────────────────────
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_SIMULATION_MODE=true
VITE_CONTRACT_ADDRESS=
VITE_RPC_URL=http://127.0.0.1:8545
VITE_API_URL=http://localhost:3001

# ── MONITORING ───────────────────────────────────
TELEMETRY_RETENTION_DAYS=90
REPORT_GENERATION_INTERVAL_HOURS=24

# ── RATE LIMITING ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
